{
  "expo": {
    "name": "Stage Stock",
    "slug": "stage-stock",
    "scheme": "stagestock",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0C0F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vellein.stagestock",
      "infoPlist": {
        "NSCameraUsageDescription": "Nécessaire pour scanner les QR codes et photographier le matériel",
        "NSPhotoLibraryUsageDescription": "Nécessaire pour accéder aux photos du matériel",
        "NFCReaderUsageDescription": "Nécessaire pour lire et écrire les puces NFC du matériel",
        "NSLocalNetworkUsageDescription": "Permet de joindre un serveur Stage Stock sur le réseau Wi‑Fi local (adresse IP du PC).",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B0C0F"
      },
      "package": "com.vellein.stagestock",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.NFC",
        "android.permission.VIBRATE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.REQUEST_INSTALL_PACKAGES"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Nécessaire pour scanner les QR codes et photographier le matériel"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Nécessaire pour accéder aux photos du matériel",
          "cameraPermission": "Nécessaire pour photographier le matériel"
        }
      ],
      "expo-notifications",
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0b1c50f3-1781-4d5e-8b21-841b8ecfb802"
      },
      "consumerApp": true
    "windowsInstallerUrl": "https://github.com/tibosory/stage-stock-app/releases/latest/download/Stagestock-Installer.exehttps://github.com/tibosory/stage-stock-app.git/releases/latest/download/Stagestock-Installer.exe https://github.com/tibosory/stage-stock-app/releases/latest/download/Stagestock-Installer.exe"
    },
    "runtimeVersion": "1.0.3",
    "updates": {
      "url": "https://u.expo.dev/7952971c-27c4-4fee-83d7-81c722620f94"
    },
    "owner": "tibo1980"
  }
}
