# Valeurs par défaut du build ; l’utilisateur peut aussi les saisir dans l’app (Paramètres → Projet Supabase).
EXPO_PUBLIC_SUPABASE_URL=https://sirjqvlieheplglbeaug.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Installateur Windows (PocketBase local) — hébergement
# L'EXE est fourni en release sur le dépôt public tibosory/stage-stock-app (asset Stagestock-Installer.exe).
# Le build source (Inno, PocketBase) vit dans le monorepo stagestock ; on duplique l'EXE en release app si besoin.
#
# Option 1 (recommandé) : URL dérivée automatiquement dans l'app depuis owner/repo
#  - app.json extra.installerGitHubRepo + build EAS (voir eas.json env EXPO_PUBLIC_INSTALLER_GITHUB_REPO)
#  - ou définir ici (prioritaire sur app.json) :
# EXPO_PUBLIC_INSTALLER_GITHUB_REPO=tibosory/stagestock
#
# Option 2 : URL HTTPS directe (prioritaire sur tout le reste) — obligatoire si le dépôt est privé
# EXPO_PUBLIC_WINDOWS_INSTALLER_URL=https://exemple.com/Stagestock-Installer.exe
# Ex. public GitHub (fichier attaché en release) :
# EXPO_PUBLIC_WINDOWS_INSTALLER_URL=https://github.com/tibosory/stage-stock-app/releases/latest/download/Stagestock-Installer.exe
#
# Après changement : reconstruire l'APK (EAS) pour intégrer la variable.
