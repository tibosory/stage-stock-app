{
  "name": "stage-stock",
  "version": "1.0.0",
  "main": "expo/AppEntry.js",
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-nfc-manager"
        ]
      }
    }
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "scripts": {
    "start": "npx expo start",
    "android": "npx expo run:android",
    "android:release": "npx expo run:android --variant release",
    "android:assemble-release": "cd android && gradlew.bat assembleRelease",
    "android:install-release": "powershell -ExecutionPolicy Bypass -File ./scripts/android-install-release.ps1 -Serial %ANDROID_SERIAL%",
    "ios": "npx expo run:ios",
    "build:android": "npx eas-cli build --platform android",
    "build:android:local": "npx eas-cli build --local --platform android",
    "build:android:preview": "npx eas-cli build --platform android --profile preview",
    "build:android:apk": "npx eas-cli build --platform android --profile preview",
    "build:apk": "npx eas-cli build --platform android --profile preview",
    "icons:build": "node scripts/build-icons.cjs",
    "icons:from-cat": "node scripts/cat-photo-to-icon-master.cjs && node scripts/build-icons.cjs",
    "icons:sync-android": "npm run icons:build && npx expo prebuild --platform android --no-install"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/stack": "^6.4.1",
    "@supabase/supabase-js": "^2.43.4",
    "date-fns": "^3.6.0",
    "expo": "~54.0.0",
    "expo-application": "~7.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.7",
    "expo-clipboard": "~8.0.8",
    "expo-crypto": "~15.0.6",
    "expo-dev-client": "~6.0.20",
    "expo-document-picker": "~14.0.6",
    "expo-file-system": "~19.0.11",
    "expo-haptics": "~15.0.6",
    "expo-image-picker": "~17.0.7",
    "expo-intent-launcher": "~13.0.8",
    "expo-linear-gradient": "~15.0.6",
    "expo-network": "~8.0.8",
    "expo-notifications": "~0.32.10",
    "expo-print": "~15.0.6",
    "expo-sharing": "~14.0.7",
    "expo-sqlite": "~16.0.8",
    "expo-status-bar": "~3.0.7",
    "expo-updates": "~29.0.16",
    "qrcode-generator": "^1.4.4",
    "react": "19.1.0",
    "react-native": "^0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-nfc-manager": "^3.16.0",
    "react-native-reanimated": "~4.1.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-signature-canvas": "^4.7.2",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "^0.5.1",
    "semver": "^7.7.4",
    "@e965/xlsx": "^0.20.3"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.1.0",
    "@types/semver": "^7.7.1",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "babel-preset-expo": "~54.0.10",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2"
  }
}
